# Cognitive Lens daemon — systemd USER service (daemonizes tools/lens_daemon.py).
# The event-driven engine: each click/chat -> a fresh headless `claude -p`. Survives logout (linger) + reboot.
#
# Install (one time):
#   mkdir -p ~/.config/systemd/user
#   cp tools/lens-daemon.service ~/.config/systemd/user/lens-daemon.service
#   systemctl --user daemon-reload
#   systemctl --user enable --now lens-daemon.service
#   loginctl enable-linger "$USER"        # keep it running when you're not logged in
# Control:  systemctl --user {status|stop|start|restart} lens-daemon   ·   journalctl --user -u lens-daemon -f
#
# NB: run the daemon OR a /loop, never both. Tune --max-per-hour / --timeout below to taste.

[Unit]
Description=Cognitive Lens daemon — event-driven engine (click/chat -> headless claude -p)
Documentation=file://%h/Claude-Wiki/05_blueprints/event-driven-autonomy.md
After=default.target

[Service]
Type=simple
WorkingDirectory=%h/Claude-Wiki
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/usr/bin/python3 %h/Claude-Wiki/tools/lens_daemon.py --timeout 900 --max-per-hour 8
Restart=on-failure
RestartSec=15

[Install]
WantedBy=default.target
